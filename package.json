{
  "name": "notiq",
  "version": "1.0.0",
  "description": "Notification microservice built with Express, Supabase, Nodemailer, and Bull.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "test": "jest --runInBand",
    "dashboard:install": "npm install --prefix dashboard",
    "dashboard:build": "npm run build --prefix dashboard",
    "setup": "npm install && npm run dashboard:install"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/anyovic1007-cmd/NotiQ.git"
  },
  "keywords": [
    "notifications",
    "express",
    "supabase",
    "nodemailer",
    "dashboard"
  ],
  "author": "Ryo",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.8",
    "bull": "^4.16.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "nodemailer": "^6.10.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node"
  }
}
